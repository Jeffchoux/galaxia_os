# Galaxia / restaurant — worker résident des agents (NON installé par défaut).
# Calqué sur ops/galaxia-tg-worker.service. À installer manuellement quand on
# voudra la boucle 24/7 :
#   sudo cp projects/restaurant/ops/galaxia-restaurant-worker.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now galaxia-restaurant-worker
# Reste sûr : tant que config dry_run=true, aucune action externe.
[Unit]
Description=Galaxia — worker résident des agents restaurant (dry-run par défaut)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=galaxia
Group=galaxia
WorkingDirectory=/home/galaxia/galaxia-project/projects/restaurant
# Clés LLM (Ollama local ne requiert rien ; Claude/Groq via .env partagé).
EnvironmentFile=-/opt/galaxia/config/.env
ExecStart=/home/galaxia/.claude/galaxia/venv/bin/python -m pipeline.worker
Restart=on-failure
RestartSec=5
Nice=10
# Durcissement (le worker n'a pas besoin de privilèges).
NoNewPrivileges=true
ProtectSystem=full
PrivateTmp=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
