#!/usr/bin/env bash
#
# <help>
# Galaxia — CLI manager-friendly.
#
# Un seul point d'entrée pour un manager non-dev (installé en /usr/local/bin/galaxia).
#
#   galaxia status        Bilan santé (services, config, veille, update)
#   galaxia version       Version installée
#   galaxia update        Force un pull immédiat de la dernière mise à jour
#   galaxia config        Relance le wizard de configuration
#   galaxia logs          Tail des logs des services Galaxia
#   galaxia veille        Déclenche manuellement la veille IA (mère uniquement)
#   galaxia help          Affiche cette aide
# </help>
#
# Volontairement minimaliste : on déclenche d'autres scripts/units, on ne
# duplique pas la logique.

set -euo pipefail

GALAXIA_DIR="${GALAXIA_DIR:-/opt/galaxia}"
# Quand le repo est checked-out (mode dev), les scripts sont à côté de ce fichier.
# En install fille standard, ils sont dans /opt/galaxia/scripts/ ou en /usr/local/bin/.
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd -P || echo "")"

# Cherche d'abord les outils dans des chemins connus. La première occurrence gagne.
find_helper() {
	local name="$1"
	for candidate in \
		"${SELF_DIR}/${name}" \
		"${GALAXIA_DIR}/current/scripts/${name}" \
		"/opt/galaxia/current/scripts/${name}" \
		"/usr/local/share/galaxia/${name}"; do
		if [ -x "$candidate" ]; then
			echo "$candidate"
			return 0
		fi
	done
	return 1
}

die() { printf '\033[1;31m[galaxia]\033[0m %s\n' "$*" >&2; exit 1; }
note() { printf '\033[1;36m[galaxia]\033[0m %s\n' "$*"; }

cmd="${1:-help}"; shift || true

case "$cmd" in
	help|-h|--help)
		# Extrait l'aide entre les marqueurs `# <help>` et `# </help>` du fichier.
		# Robuste face aux décalages de lignes quand on édite l'en-tête.
		sed -n '/^# <help>$/,/^# <\/help>$/p' "$0" \
			| grep -v '^# <\?/\?help>$' \
			| sed 's/^# \{0,1\}//'
		exit 0
		;;

	status)
		path="$(find_helper health.sh)" || die "health.sh introuvable — installation incomplète."
		exec bash "$path" "$@"
		;;

	version)
		if [ -f "$GALAXIA_DIR/VERSION" ]; then
			cat "$GALAXIA_DIR/VERSION"
		else
			echo "(version inconnue — galaxia-update n'a pas encore tourné)"
		fi
		;;

	update)
		case "${1:-}" in
			--check|-n)
				note "Pull en mode check (n'applique rien) — non implémenté côté script, voir docs/UPDATES.md"
				exit 2
				;;
			*) ;;
		esac
		if ! command -v systemctl >/dev/null 2>&1; then
			die "systemctl indisponible — environnement non-systemd."
		fi
		note "Déclenchement de galaxia-update.service (synchrone)..."
		sudo systemctl start galaxia-update.service
		note "Logs :"
		sudo journalctl -u galaxia-update.service -n 30 --no-pager
		;;

	config|wizard)
		path="$(find_helper wizard.sh)" || die "wizard.sh introuvable — installation incomplète."
		# Wizard veut être lancé en root pour écrire /opt/galaxia/config/
		if [ "$(id -u)" -ne 0 ]; then
			exec sudo GALAXIA_CONFIG_DIR="$GALAXIA_DIR/config" bash "$path" "$@"
		else
			exec env GALAXIA_CONFIG_DIR="$GALAXIA_DIR/config" bash "$path" "$@"
		fi
		;;

	logs)
		if systemctl list-unit-files galaxia-update.service >/dev/null 2>&1; then
			sudo journalctl -u galaxia-update.service -u galaxia-veille.service -n 100 --no-pager
		else
			sudo journalctl -u galaxia-veille.service -n 100 --no-pager 2>/dev/null \
				|| die "Aucune unit galaxia-* trouvée. La galaxie est-elle installée ?"
		fi
		;;

	veille)
		systemctl list-unit-files galaxia-veille.service >/dev/null 2>&1 \
			|| die "galaxia-veille.service absent — cette commande n'a de sens que sur la galaxie mère."
		note "Déclenchement de galaxia-veille.service (synchrone, ~2-5 min sur CPU)..."
		sudo systemctl start galaxia-veille.service
		sudo journalctl -u galaxia-veille.service -n 30 --no-pager
		;;

	*)
		die "Commande inconnue : '$cmd'. Voir 'galaxia help'."
		;;
esac
