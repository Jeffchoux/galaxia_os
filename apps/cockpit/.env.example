# Clé API Claude (obligatoire). Réutilise /opt/galaxia/config/.env si présent.
ANTHROPIC_API_KEY=

# Email de l'utilisateur admin (Jeff). Sera créé en base au premier démarrage
# avec le role `admin`, et toutes les conversations existantes lui seront
# rattachées par migration. Obligatoire depuis Sprint 2 (multi-user).
ADMIN_EMAIL=

# Hash argon2id du mot de passe Jeff. Générer avec :
#   node -e "import('@node-rs/argon2').then(a=>a.hash(process.argv[1]).then(console.log))" -- "<mot-de-passe>"
JEFF_PASS_HASH=

# Secret pour signer les cookies de session. 32+ octets random.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# Modèle Claude (défaut : claude-opus-4-7 pour la qualité ; sonnet-4-6 si économe).
COCKPIT_MODEL=claude-opus-4-7

# Chemin du fichier SQLite (défaut : ./data/cockpit.db).
COCKPIT_DB_PATH=./data/cockpit.db

# Racines accessibles au MCP server filesystem (CSV de paths absolus).
# Mettre `-` pour désactiver complètement. Défaut : repo Galaxia + briefs + knowledge.
# COCKPIT_MCP_FS_ROOTS=/home/galaxia/galaxia-project,/home/galaxia/.claude/galaxia/briefs

# GitHub Personal Access Token pour le MCP server github. Si absent, le server
# n'est pas démarré. Scope minimum : `public_repo` (read) ou `repo` (read privé +
# create issues/comments si on veut Galaxia capable d'ouvrir des PR/issues).
# Génération : https://github.com/settings/tokens/new?scopes=public_repo&description=galaxia-cockpit
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Brave Search API key (recherche web indépendante de Google). Plan Free
# = 2000 queries/mois suffisant pour un usage perso quotidien.
# Génération : https://api.search.brave.com/app/keys
# BRAVE_API_KEY=BSA_xxxxxxxxxxxxxxxxxxxx

# Wake word "Hey Galaxia" — Picovoice Porcupine WASM (Sprint 3 — Volet A.1).
# Free tier perso suffit pour le dogfooding-mère. Sans clé, le filtre regex
# actuel reste utilisé. Voir static/wake/README.md pour la procédure complète.
#   1. https://console.picovoice.ai/ → onglet AccessKey
#   2. Train Wake Word "Hey Galaxia" (FR) → télécharger le .ppn
#   3. Déposer hey_galaxia_fr.ppn + porcupine_params_fr.pv dans static/wake/
# PUBLIC_PICOVOICE_ACCESS_KEY=

# Mail provider pour les magic links de connexion (Sprint 2).
# - `console` (défaut) : log le magic link dans journalctl, utilisé en dev et CI.
# - `brevo` : envoie un email transactionnel via Brevo (api.brevo.com). Plan
#   freemium 300 emails/jour à vie, créer une clé sur https://app.brevo.com/settings/keys/api
# MAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
# MAIL_FROM=no-reply@galaxia-os.com
# MAIL_FROM_NAME=Galaxia
