# Application principale — cockpit SvelteKit (apps/cockpit).
# Service systemd `galaxia-cockpit.service` écoute sur 127.0.0.1:3001.
# Caddy fait le TLS + envoie X-Forwarded-* (utilisé par adapter-node pour
# reconstruire l'Origin attendu par le CSRF check de SvelteKit).
app.galaxia-os.com {
	encode gzip zstd
	reverse_proxy 127.0.0.1:3001 {
		# SSE: pas de buffering pour le streaming Claude live.
		flush_interval -1
	}
}

# Redirection du domaine apex vers l'app
galaxia-os.com {
	redir https://app.galaxia-os.com{uri} permanent
}

# Installer public — `curl -fsSL https://install.galaxia-os.com | sudo bash`.
# Le fichier servi est /var/www/galaxia-install/install.sh, recopié depuis
# scripts/install.sh par `scripts/sync-www.sh` (sync manuel — voir CLAUDE.md).
install.galaxia-os.com {
	encode gzip zstd
	root * /var/www/galaxia-install
	@root path /
	rewrite @root /install.sh
	file_server
	header Content-Type "text/x-shellscript; charset=utf-8"
}

# Endpoint Hub & Spoke — les manifests signés cosign sont publiés ici par
# `scripts/galaxia-publish.sh` (webroot GALAXIA_WEBROOT=/var/www/galaxia-updates).
# Tant que la première publication n'a pas eu lieu, /manifests/ renverra 404
# proprement et le client `galaxia-update.sh` traitera ça comme "rien à faire".
updates.galaxia-os.com {
	encode gzip zstd
	root * /var/www/galaxia-updates
	file_server
}

# Documentation — pour l'instant, simple redirection vers le repo public.
# Quand on aura un vrai site doc (mkdocs/docusaurus), basculer sur file_server.
docs.galaxia-os.com {
	redir https://github.com/Jeffchoux/galaxia_os{uri} permanent
}

# Dashboard NemoClaw — reverse proxy souverain (remplace cloudflared tunnel).
# Dépendance : `nemoclaw galaxia-main recover` doit avoir posé le port-forward
# SSH local 127.0.0.1:18789 (sinon Caddy renvoie 502).
# Auth : token NemoClaw dans le fragment URL (#token=...) géré par le dashboard JS.
# Récupérer l'URL avec token via : sudo -u galaxia nemoclaw galaxia-main dashboard-url -q
nemoclaw.galaxia-os.com {
	encode gzip zstd
	reverse_proxy 127.0.0.1:18789 {
		# WebSocket-friendly : pas de buffering si le dashboard en utilise.
		flush_interval -1
	}
}

# === Projet BabyRun — Lina (agent vocal Twilio<->OpenAI Realtime) ===
# Service Node sur 127.0.0.1:3000, WebSocket upgrade pour /twilio/stream.
# Auto-TLS Let's Encrypt via Caddy. Le fichier deploy/nginx.conf sous
# /opt/lina est livré comme alternative documentée si on doit migrer.
lina.babyrun.re {
	encode gzip zstd
	@stream path /twilio/stream
	reverse_proxy @stream 127.0.0.1:3000 {
		# Pas de buffering pour les WS — laisser passer en streaming.
		flush_interval -1
	}
	reverse_proxy 127.0.0.1:3000
}
