# Galaxia — configuration Caddy de la galaxie mère
# Source de vérité : ce fichier. Le fichier déployé est /etc/caddy/Caddyfile
# (synchronisé manuellement pour l'instant — à automatiser via docker-compose
# ou systemd path unit plus tard).

{
	email jeffchoux@hotmail.com
}

# Application principale — placeholder en attendant l'interface Galaxia
app.galaxia-os.com {
	root * /var/www/galaxia
	file_server
	encode gzip zstd
}

# Redirection du domaine apex vers l'app
galaxia-os.com {
	redir https://app.galaxia-os.com{uri} permanent
}

