# Galaxia — bot Telegram, modèle de configuration.
# Copier vers .env (gitignored) et compléter.

# Token obtenu via @BotFather sur Telegram
BOT_TOKEN=123456:ABC-DEF...

# chat_id personnel autorisé — laisser 0 au premier démarrage, faire /start
# au bot, il te répondra ton chat_id, puis le coller ici (et relancer le service).
ALLOWED_CHAT_ID=0

# Chemin de l'inbox URLs (TikTok/X). Défaut : ~/.claude/galaxia/inbox.md
# INBOX_PATH=/home/galaxia/.claude/galaxia/inbox.md

# Chemin de la SQLite du cockpit (pour push des documents/photos).
# Défaut : /home/galaxia/galaxia-project/apps/cockpit/data/cockpit.db
# COCKPIT_DB_PATH=/home/galaxia/galaxia-project/apps/cockpit/data/cockpit.db
